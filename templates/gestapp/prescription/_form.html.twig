                            form_label: 'L\'auto évaluation du bénéficiaire a été réalisée avant l\'action.',
                            disabled: false
                        } %}
                    </div>
                {% endif %}

            </div>
        </div>

        {#  Bloc des objectifs de la médiation à complêter par le Médiateur sélectionné #}
