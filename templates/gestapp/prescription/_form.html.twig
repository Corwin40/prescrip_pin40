    {% if prescription.step.name == 'Open' or prescription.step.name == 'OneParts' %}
        <div class="row">
            <div class="col-12 bg-light border-bottom border-dark mb-2">
                <h2 class="h4 mt-1 mb-1">Construction du dossier</h2>
            </div>
            <div class="col-12">
                {% if role == 'Administrateur' %}
                    <p class="mb-0">Ce dossier ne pourra pas être finalisé sans la validation par les 2 parties : l'organisme de prescriptions et le lieu de médiation.</p>
                {% elseif role == 'Prescripteur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <p class="mb-0">Vous devez vérifier que la prescription corresponde aux besoins identifiés pour votre bénéficiaire.</p>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <p class="mb-0">En validant la demande, le médiateur sélectionné va être averti de l'ouverture du dossier.</p>
                    {% endif %}
                {% elseif role == 'Médiateur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <p class="mb-0">Cette prescription doit être vérifiée par le prescripteur dont dépend le bénéficiaire.</p>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <p class="mb-0"></p>
                    {% endif %}
                {% endif %}
            </div>
            <div class="col-6 mt-4 mb-4">
                <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_dashboard_index') }}"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
                {% if role == 'Administrateur' %}
                    <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Préenregistrer la demande</button>
                {% elseif role == 'Prescripteur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Poursuivre la demande</button>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Préenregistrer la demande</button>
                    {% endif %}
                {% elseif role == 'Médiateur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Préenregistrer la demande</button>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Poursuivre la demande</button>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    {% elseif prescription.step.name == 'TwoParts' %}
        <div class="row">
            <div class="col-12 bg-light border-bottom border-dark mb-2">
                <h3 class="mt-1 mb-1 h4">Poursuite du dossier</h3>
            </div>
            <div class="col-12">

                {% if role == 'Administrateur' %}
                    <p class="mb-0">Vous completez en lieu et place de l'un des organismes cette prescription. Le bénéficiaire doit suivre son parcours de formation précisé précédemment avant de recevoir la dotation.</p>
                {% elseif role == 'Prescripteur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <p class="mb-0">En l'état actuel de la prescription, en tant que prescripteur, vous ne pouvez pas valider le parcours de formation du bénéficiaire.</p>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <p class="mb-0">En l'état actuel de la prescription, en tant que prescripteur, vous ne pouvez pas valider le parcours de formation du bénéficiaire.</p>
                    {% endif %}
                {% elseif role == 'Médiateur' %}
                    {% if prescription.status.name == 'OpenByMediator' %}
                        <p class="mb-0">Vous validez le parcours de formation du bénéficiaire. Ce denier doit suivre son parcours de formation précisé précédemment avant de recevoir la dotation.</p>
                    {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                        <p class="mb-0">Vous validez le parcours de formation du bénéficiaire. Ce denier doit suivre son parcours de formation précisé précédemment avant de recevoir la dotation.</p>
                    {% endif %}
                {% endif %}
            </div>
            <div class="row mt-2">
                <div class="col-4">
                    <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_dashboard_index') }}"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
                    {% if role == 'Administrateur' %}
                        <button id="btnValidCase" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Validation parcours de formation</button>
                    {% elseif role == 'Prescripteur' %}
                    {% elseif role == 'Médiateur' %}
                        <button id="btnValidCase" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Validation parcours de formation</button>
                    {% endif %}
                </div>
            </div>
        </div>
    {% elseif prescription.step.name == 'ChoiceEquipment' %}
        <div class="row">
            <div class="col-12 bg-light border-bottom border-dark mb-2">
                <h3 class="mt-1 mb-1 h4">Choix de l'équipement</h3>
            </div>
            <div class="col-12">
                {% if role == 'Administrateur' %}
                    <p class="mb-0">Vous completez en lieu et place de l'un des organismes cette prescription.</p>
                {% elseif role == 'Prescripteur' %}
                    <p class="mb-0">En l'état actuel de la prescription, en tant que prescripteur, vous ne pouvez pas choisir un équipement.</p>
                {% elseif role == 'Médiateur' %}
                    <p class="mb-0">Choisissez l'ID de l'équipement attribué au bénéficiaire.</p>
                {% endif %}
            </div>
            <div class="row mt-2">
                {% if role == 'Administrateur' or role =='Médiateur' %}
                <div class="col-4">
                    {% include 'composants/inputs/input_select.html.twig' with {
                        label: 'Référence de l\'équipement doté',
                        field: form.equipement,
                        disabled: ''
                    } %}
                </div>
                <div class="clear"></div>
                <div class="col-4">
                    <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_dashboard_index') }}"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
                    <button id="btnValidCase" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Validation de l'équipement</button>
                </div>
                {% elseif role == 'Prescripteur' %}
                    <div class="col-4">
                        <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_dashboard_index') }}"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

{{ form_end(form) }}

