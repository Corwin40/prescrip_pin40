                            } %}
                            {% include 'composants/inputs/input_radio_tablerow.html.twig' with {
                                form_label: 'Messagerie electronique',
                                form_field: form.competence.compEmail,
                                disabled: false
                            } %}
                        {% endif %}

                    </table>
                </div>

                {% if role == 'Prescripteur' %}
                    <div class="col-md-6">
