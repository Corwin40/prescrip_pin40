<div class="row mb-1 justify-content-between">
    <div class="col-6">
        <p class="mb-0 text-secondary fst-italic">Réf : {{ prescription.ref }} | Ce dossier à été ouvert par
            {% if prescription.isOpenByPrescriptor == 1 and prescription.isOpenByMediator == 0 %}
                un precripteur : {{ prescription.membre.nameStructure }}.
            {% elseif prescription.isOpenByPrescriptor == 0 and prescription.isOpenByMediator == 1 %}
                un epace de médiation : {{ prescription.lieuMediation.nameStructure }}.
            {% else %}
                un administrateur.
            {% endif %}
        </p>
    </div>
    <div class="col-2 align-items-end">
        <p class="mb-0 me-2 text-end">
            {{ include('composants/pages/badge.html.twig') }}
        </p>
    </div>
</div>

