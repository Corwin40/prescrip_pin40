<div class="row mb-1 justify-content-between">
    <div class="col-6">
        <p class="mb-0 text-secondary fst-italic">Réf : {{ prescription.ref }} | Ce dossier à été ouvert par
            {% if prescription.status.name == 'OpenByPrescriptor' %}
                un prescripteur.
            {% elseif prescription.status.name == 'OpenByMediator' %}
                un espace de médiation.
            {% elseif prescription.status.name == 'OpenByAdministrator' %}
                un administrateur.
            {% endif %}
        </p>
    </div>
    <div class="col-2 align-items-end">
        <p class="mb-0 me-2 text-end">
            {{ include('composants/pages/badge.html.twig') }}
        </p>
    </div>
</div>

<div class="row">
    <div class="col-12">
        {% if role == 'Administrateur' %}
            <p class="mb-2 alert alert-info">Ce dossier ne pourra pas être finalisé sans la validation par les 2 parties : l'organisme de prescriptions et le lieu de médiation.</p>
        {% elseif role == 'Prescripteur' %}
            {% if prescription.status.name == 'OpenByMediator' %}
                {% if prescription.step.name == 'OneParts' %}{% else %}{% endif %}
                <p class="mb-2 alert alert-info">Vous devez vérifier que la prescription corresponde aux besoins identifiés pour votre bénéficiaire.</p>
            {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                {% if prescription.step.name == 'OneParts' %}
                    <p class="mb-2 alert alert-info">Pour être complête, cette prescription doit être coécrite par le médiateur choisi. Ce dernier va être averti de l'ouverture du dossier.</p>
                {% else %}
                {% endif %}
            {% endif %}
        {% elseif role == 'Médiateur' %}
            {% if prescription.status.name == 'OpenByMediator' %}
                <p class="mb-2 alert alert-info">Cette prescription doit être vérifiée par le prescripteur dont dépend le bénéficiaire.</p>
            {% elseif prescription.status.name == 'OpenByPrescriptor' %}
                <p class="mb-2 alert alert-info">Completez le parcours de formation adapté aux besoins du bénéficiaire.</p>
            {% endif %}
        {% endif %}
    </div>
</div>

