{% extends 'base.html.twig' %}

{% block title %}Liste des prescriptions{% endblock %}

{% block body %}

    {# Bloc entête de page #}
    {%
        include 'composants/pages/pages_headers.html.twig' with {
        'page_title' : 'Liste des prescriptions',
        'li_items': [
            { path: 'app_admin_dashboard_index', fa_class: 'fa-sharp-duotone fa-solid fa-house-blank', a_title: 'Dashboard' },
            { path: null, fa_class: 'fa-sharp fa-light fa-laptop', a_title: 'prescription' },
        ],
        'btns' : [
            {'path': path('app_gestapp_prescription_new'), 'id':'btnAddprescription', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter une prescription'},
        ]
    }
    %}

    {# Bloc contenu de la page #}
    <div class="row mt-3">
        <div class="col-12">
            {% if prescriptions is not empty %}
                <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle">
                        <thead>
                        <tr>
                            <th>Référence</th>
                            <th>Prescripteur</th>
                            <th>Bénéficiaire</th>
                            <th>Modifié le</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for prescription in prescriptions %}
                            <tr>
                                <td>{{ prescription.ref }}</td>
                                <td>{{ prescription.membre }}</td>
                                <td>
                                    {{ prescription.beneficiaire.firstname }} {{ prescription.beneficiaire.lastname }}
                                    {% if prescription.isOpenByPrescriptor == 1 and prescription.isOpenByMediator == 0 %}
                                        <span class="badge text-bg-info">
                                        Prescription en cours&nbsp;<i class="fa-light fa-badge-check"></i>
                                    </span>
                                    {% endif %}
                                    {% if prescription.isOpenByPrescriptor == 0 and prescription.isOpenByMediator == 1 %}
                                        <span class="badge text-bg-info">
                                        Prescription en cours&nbsp;<i class="fa-light fa-badge-check"></i>
                                    </span>
                                    {% endif %}
                                    {% if prescription.isOpenByPrescriptor == 1 and prescription.isOpenByMediator == 1 and prescription.validcase is true %}
                                        <span class="badge text-bg-success">
                                        Prescription éditée&nbsp;<i class="fa-light fa-badge-check"></i>
                                    </span>
                                    {% endif %}
                                </td>
                                <td>{{ prescription.updatedAt ? prescription.updatedAt|date('d/m/Y') : '' }}</td>
                                <td class="text-center">
                                    <a href="{{ path('app_gestapp_prescription_edit', {'id': prescription.id}) }}" class="text-dark text-decoration-none"><i class="fa-duotone fa-solid fa-user-pen"></i>&nbsp;Modifier</a>
                                    <a href="{{ path('app_gestapp_prescription_delete', {'id': prescription.id}) }}" class="text-dark text-decoration-none"><i class="fa-duotone fa-solid fa-user-circle-minus"></i>&nbsp;Supprimer</a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead>
                    <tr>
                        <th>Référence</th>
                        <th>Prescripteur</th>
                        <th>Bénéficiaire</th>
                        <th>Modifié le</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-start text-muted" colspan="5">Aucune prescription trouvée.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
