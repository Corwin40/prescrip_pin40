{#  Bloc Prescripteur #}
<div class="col-12 mb-2">
    <div class="row">
        <div class="col-12 bg-light border-bottom border-dark mb-2">
            <h2 class="mt-1 mb-1 px-2 pt-1 h4">Le prescripteur</h2>
        </div>
    </div>

    {% if role == 'Administrateur' or role == 'Médiateur' %}
        <div class="row">
            <div class="col-md-6">
                {% if role == 'Médiateur' %}
                    {% include 'composants/inputs/input_select.html.twig' with {
                        label: 'Sélectionner la structure de prescription',
                        field: form.prescriptor,
                        disabled: ''
                    } %}
                {% else %}
                    <p class="mb-0 alert alert-warning">Le bénéficiaire étant enregistré par ou avec un organisme de prescription, le prescripteur choisi sera ce dernier.</p>
                    {% include 'composants/inputs/input_select.html.twig' with {
                        label: 'Sélectionner la structure de prescription',
                        field: form.prescriptor,
                        disabled: true
                    } %}
                {% endif %}
            </div>
        </div>
    {% elseif role == 'Prescripteur' %}

        <table class="table">
            <tr>
                <td class="col-1">
                    <div class="d-flex gap-1">
                        <div><i class="fa-duotone fa-light fa-building"></i></div>
                        <div>Structure&nbsp;</div>
                    </div>
                </td>
                <td class="col-2">
                    <p class="mb-0 fw-semibold">{{ app.user.structure.name }}</p>
                </td>
                <td class="col-1">
                    <div class="d-flex gap-1">
                        <div><i class="fa-duotone fa-solid fa-user"></i></div>
                        <div>Responsable&nbsp;</div>
                    </div>
                </td>
                <td class="col-2">
                    {% if app.user.structure.contactResponsableFirstname is empty and app.user.structure.contactResponsableLastname is empty %}
                        -
                    {% else %}
                        <p class="mb-0 fw-semibold">{{ app.user.structure.contactResponsableFirstname }} {{ app.user.structure.contactResponsableLastname }}</p>
                    {% endif %}
                </td>
                <td class="col-1">
                    <div class="d-flex gap-1">
                        <div><i class="fa-duotone fa-light fa-phone"></i></div>
                        <div>Téléphone&nbsp;</div>
                    </div>
                </td>
                <td class="col-2">
                    {% if app.user.structure.contactPhone is empty %}
                        -
                    {% else %}
                        <p class="mb-0 fw-semibold">{{ app.user.structure.contactPhone }}</p>
                    {% endif %}
                </td>
                <td class="col-1">
                    <div class="d-flex gap-1">
                        <div><i class="fa-duotone fa-solid fa-inbox"></i></div>
                        <div>Email&nbsp;</div>
                    </div>
                </td>
                <td class="col-2">
                    {% if app.user.structure.contactEmail is empty %}
                        -
                    {% else %}
                        <p class="mb-0 fw-semibold">{{ app.user.structure.contactEmail }}</p>
                    {% endif %}
                </td>
            </tr>
        </table>
    {% endif %}
</div>
