{% extends 'base.html.twig' %}

{% block title %}Détails du bénéficiaire{% endblock %}

{% block body %}

    {# Bloc entête de page #}
    {%
        include 'composants/pages/pages_headers.html.twig' with {
        'page_title' : 'Liste des Bénéficiaires',
        'li_items': [
            { path: 'app_admin_dashboard_index', fa_class: 'fa-sharp-duotone fa-solid fa-house-blank', a_title: 'Dashboard' },
            { path: 'app_gestapp_beneficiary_index', fa_class: 'fa-sharp fa-light fa-laptop', a_title: 'Bénéficiaires' },
            { path: null, fa_class: null , a_title: 'Voir un.e bénéficiaire' },
        ],
        'btns' : [
            {'path': path('app_gestapp_beneficiary_new'), 'id':'btnAddBeneficiaire', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter un.e bénéficiaire'},
        ]

    }
    %}

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-1 border-dark">
                <div class="card-body">
                    <div class="row g-4">

                        {# =======================
                            COLONNE BÉNÉFICIAIRE
                        ======================== #}
                        <div class="col-lg-8">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width:60px;height:60px;">
                                    <i class="fa-duotone fa-light fa-user-vneck-hair-long fs-3"></i>
                                </div>
                                <div>
                                    <h4 class="mb-0">
                                        {{ beneficiary.civility }} {{ beneficiary.firstname }} {{ beneficiary.lastname }}
                                    </h4>
                                    <p class="mb-0">Tranche d'age : <span class="badge bg-primary-subtle text-primary fw-normal">{{ beneficiary.ageGroup }} ans</span></p>
                                </div>
                            </div>

                            <hr>

                            <div class="row mb-1 justify-content-between">
                                <div class="col-sm-4 text-muted">Situation :</div>
                                <div class="col-sm-8 fw-semibold text-end">{{ beneficiary.professionnalStatus }}</div>
                            </div>

                            <div class="row mb-1 justify-content-between">
                                <div class="col-sm-4 text-muted">Prescription :</div>
                                {% if beneficiary.prescription|length > 0 %}
                                    <div class="col-sm-8 fw-semibold text-end">{{ beneficiary.prescription.ref }}</div>
                                {% else %}
                                    <div class="col-sm-8 fw-semibold text-end">Aucune prescription en cours</div>
                                {% endif %}
                            </div>

                            <div class="row small text-muted mt-4">
                                <div class="col-sm-6">
                                    <i class="bi bi-calendar-plus me-1"></i>
                                    Créé le : {{ beneficiary.createdAt ? beneficiary.createdAt|date('d/m/Y') : '' }}
                                </div>
                                <div class="col-sm-6">
                                    <i class="bi bi-pencil-square me-1"></i>
                                    Modifié le : {{ beneficiary.updatedAt ? beneficiary.updatedAt|date('d/m/Y') : '' }}
                                </div>
                            </div>

                        </div>

                        {# =======================
                            COLONNE PRESCRIPTEUR
                        ======================== #}
                        <div class="col-lg-4">
                            <div class="card bg-light border-0 h-100">
                                <div class="card-body">
                                    <h6 class="text-uppercase text-muted mb-3">
                                        Prescripteur
                                    </h6>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center me-3" style="width:50px;height:50px;">
                                            <i class="bi bi-building"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">
                                                {{ beneficiary.prescriptor.nameStructure }}
                                            </div>
                                            <small class="text-muted">{{ beneficiary.prescriptor.address }}<br>{{ beneficiary.prescriptor.zipcode }} {{ beneficiary.prescriptor.city }}</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>


{% endblock %}
