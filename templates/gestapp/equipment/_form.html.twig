<section>
    {{ form_start(form) }}

    <div class="row g-2">
        <h2 class="h4 mb-0">Le matériel</h2>
        <div class="col-md-2">
            {% include 'composants/inputs/input_text.html.twig' with {
                label: 'Id',
                field: form.equipmentId,
                disabled: false
            } %}
        </div>
        <div class="col-md-2">
            {% include 'composants/inputs/input_text.html.twig' with {
                label: 'Matricule',
                field: form.matriculEquipment,
                disabled: false
            } %}
        </div>
        <div class="col-md-2">
            {% include 'composants/inputs/input_select.html.twig' with {
                label: 'Type d’équipement',
                field: form.typeEquipment
            } %}
        </div>
        <div class="col-md-2">
            {% include 'composants/inputs/input_text.html.twig' with {
                label: 'Marque',
                field: form.brandEquipment,
                disabled: false
            } %}
        </div>

        <div class="col-md-2">
            {% include 'composants/inputs/input_select.html.twig' with {
                label: 'OS installé',
                field: form.osInstalled
            } %}
        </div>
        <div class="col-md-2">
            {% include 'composants/inputs/input_select.html.twig' with {
                label: 'Statut',
                field: form.statusEquipment
            } %}
        </div>
    </div>
    <div class="row g-2">
        <h2 class="h4 mb-0">Informations complémentaires</h2>
        <div class="col-md-8">
            {% include 'composants/inputs/input_textarea.html.twig' with {
                label: 'Notes',
                field: form.note
            } %}
        </div>
        <div class="clear"></div>
        <div class="col-md-3">
            {% include 'composants/inputs/input_text.html.twig' with {
                label: 'Réceptionné par le lieu de médiation',
                field: form.recoveryAt,
                disabled: false
            } %}
        </div>

        <div class="col-4 pt-4 mt-4 ps-4">
            {% include 'composants/forms/check_verif.html.twig' with {
                label: 'Disponible',
                field: form.isDispo
            } %}
        </div>

    </div>

    <div class="row">
        <div class="col-6 mt-4 mb-4">
            <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_dashboard_index') }}"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
            <button id="btnAddPrescription" class="btn btn-outline-primary btn-sm"><i class="fa-duotone fa-solid fa-circle-check"></i> Ajouter l'équipement</button>
        </div>
    </div>
    {{ form_end(form) }}
</section>

