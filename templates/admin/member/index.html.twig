{% extends 'base.html.twig' %}

{% block title %}Liste des membres{% endblock %}

{% block body %}

    {# Bloc entête de page #}
    <section id="page_header">
        {%
            include 'composants/pages/pages_headers.html.twig' with {
            'page_title' : 'Liste des Membres',
            'li_items': [
                { path: 'app_admin_dashboard_index', fa_class: 'fa-sharp-duotone fa-solid fa-house-blank', a_title: 'Dashboard' },
                { path: null, fa_class: 'fa-sharp fa-light fa-laptop', a_title: 'Membres' },
            ],
            'btns' : [
                {'path': path('app_admin_member_new', {'role': 'prescripteur'}), 'id':'btnAddMembre', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter un.e prescripteur'},
                {'path': path('app_admin_member_new', {'role': 'mediateur'}), 'id':'btnAddMembre', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter un.e mediateur'},
            ]
        }
        %}
    </section>

    <section id="page_content">
        {% if members is not empty %}
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Membre</th>
                        <th>Structure</th>
                        <th>Adresse</th>
                        <th>Contacts</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for member in members %}
                        {% set role = 'aucun' %}
                        {% if member.roles|first == 'ROLE_SUPER_ADMIN' or member.roles|first == 'ROLE_ADMIN' %}
                            {% set role = 'Administrateur' %}
                        {% elseif member.roles|first == 'ROLE_MEDIATEUR' %}
                            {% set role = 'Médiateur' %}
                        {% elseif member.roles|first == 'ROLE_PRESCRIPTEUR' %}
                            {% set role = 'Prescripteur' %}
                        {% elseif member.roles|first == 'ROLE_RECONDITIONNEUR' %}
                            {% set role = 'Reconditionneur' %}
                        {% endif %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>{{ member.structure.contactResponsableCivility }} {{ member.structure.contactResponsableFirstname }} {{ member.structure.contactResponsableLastname }}</div>
                                    <div>
                                        {% if role == "Administrateur" %}
                                            <span class="badge text-bg-danger py-2">{{ role }}</span>
                                        {% elseif role == "Médiateur" %}
                                            <span class="badge text-bg-success py-2">{{ role }}</span>
                                        {% elseif role == "Prescripteur" %}
                                            <span class="badge text-bg-primary py-2">{{ role }}</span>
                                        {% elseif role == "Reconditionneur" %}
                                            <span class="badge text-bg-warning py-2">{{ role }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="fw-semibold">{{ member.structure.name }}</span><br>
                                {{ member.email }}
                            </td>
                            <td>{{ member.structure.address }}<br>{{ member.structure.zipcode }} {{ member.structure.city }}</td>
                            <td>{{ member.structure.contactEmail }}<br>{{ member.structure.contactPhone }}</td>
                            <td class="text-center">
                                <a href="{{ path('app_admin_member_edit', {'id': member.id}) }}" class="text-dark text-decoration-none"><i class="fa-duotone fa-solid fa-user-pen"></i></a>&nbsp;&nbsp;&nbsp;
                                <a href="{{ path('app_admin_member_delete', {'id': member.id}) }}" class="text-dark text-decoration-none openModal" ><i class="fa-duotone fa-solid fa-user-circle-minus"></i></a>&nbsp;&nbsp;&nbsp;
                                <a href="{{ path('app_admin_member_renew_password', {'id': member.id}) }}" class="text-dark text-decoration-none openModal" data-bs-data="RESETPASSWORD-Changement du mot de passe-"><i class="fa-light fa-key"></i></a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-center">Aucun membre trouvé.</p>
        {% endif %}
    </section>




{% endblock %}
