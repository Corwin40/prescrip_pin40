{% extends 'base.html.twig' %}

{% block title %}Liste des membres{% endblock %}

{% block body %}

    {# Bloc entête de page #}
    <section id="page_header">
        {%
            include 'composants/pages/pages_headers.html.twig' with {
            'page_title' : 'Liste des Membres',
            'li_items': [
                { path: 'app_admin_dashboard_index', fa_class: 'fa-sharp-duotone fa-solid fa-house-blank', a_title: 'Dashboard' },
                { path: null, fa_class: 'fa-sharp fa-light fa-laptop', a_title: 'Membres' },
            ],
            'btns' : [
                {'path': path('app_admin_member_new', {'role': 'prescripteur'}), 'id':'btnAddMembre', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter un.e prescripteur'},
                {'path': path('app_admin_member_new', {'role': 'mediateur'}), 'id':'btnAddMembre', 'class' : 'btn btn-outline-dark btn-sm', 'fa_class' : 'fa-duotone fa-solid fa-circle-user-circle-plus', 'textcontent' : 'Ajouter un.e mediateur'},
            ]
        }
        %}
    </section>

    <section id="page_content">
        {% if members is not empty %}
            <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Membre</th>
                        <th>Structure</th>
                        <th>Adresse</th>
                        <th>Contacts</th>
                        <th>Vérifié</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for member in members %}
                        <tr>
                            <td>{{ member.id }}</td>
                            <td>{{ member.contactResponsableCivility }} {{ member.contactResponsableFirstname }} {{ member.contactResponsableLastname }}</td>
                            <td>
                                {{ member.nameStructure }}<br>
                                {{ member.email }}
                            </td>
                            <td>{{ member.address }}<br>{{ member.zipcode }} {{ member.city }}</td>
                            <td>{{ member.contactEmail }}<br>{{ member.contactPhone }}</td>
                            <td>
                                {% if member.isVerified %}
                                    <span class="badge bg-success">Oui</span>
                                {% else %}
                                    <span class="badge bg-danger">Non</span>
                                {% endif %}
                            </td>
                            <td class="text-center">

                                {# Bouton "Voir" #}
                                {% include 'composants/forms/button_link.html.twig' with {
                                    label: 'Voir',
                                    href: path('app_admin_member_show', {'id': member.id}),
                                    type: 'info'
                                } %}

                                {# Bouton "Modifier" #}
                                {% include 'composants/forms/button_link.html.twig' with {
                                    label: 'Modifier',
                                    href: path('app_admin_member_edit', {'id': member.id}),
                                    type: 'warning'
                                } %}

                                {# Bouton "Supprimer" si  il existe #}
                                {% include 'composants/forms/buttons_delete.html.twig' with {
                                    id: member.id,
                                    route: 'app_admin_member_delete'
                                } %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-center">Aucun membre trouvé.</p>
        {% endif %}
    </section>




{% endblock %}
