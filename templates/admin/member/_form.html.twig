{{ form_start(form, {'attr': {'id': 'member_form'}}) }}

<div class="row g-2 mb-3">
    <div class="col-12 bg-light border-bottom border-dark mb-2">
        <h3 class="mt-1 mb-1 h4">La structure</h3>
    </div>
    <div class="col-md-2">
        {{ form_label(form.nameStructure, 'Nom', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.nameStructure, {'attr': {'class': 'form-control form-control-sm'}}) }}
    </div>
    <!-- Email -->
    <div class="col-md-2">
        {{ form_label(form.email, 'Email principal', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-sm'}}) }}
    </div>
    <div class="col-2"></div>
    <!-- Civilité -->
    <div class="col-md-6">
        {{ form_label(form.contactResponsableCivility, 'Responsable :', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        <div class="row">
            <div class="col-12">
                <div class="input-group">
                    {{ form_widget(form.contactResponsableCivility, {'attr': {'class': 'form-select w-25 form-select-sm'}}) }}
                    {{ form_widget(form.contactResponsableFirstname, {'attr': {'class': 'form-control w-auto form-control-sm'}}) }}
                    {{ form_widget(form.contactResponsableLastname, {'attr': {'class': 'form-control w-auto form-control-sm'}}) }}
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row g-1 mb-3">

    <div class="col-12 bg-light border-bottom border-dark mb-2">
        <h3 class="mt-1 mb-1 h4">Contacts</h3>
    </div>
    <!-- Structure & adresse -->

    <div class="col-md-6">
        {{ form_label(form.address, 'Adresse', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.address, {'attr': {'class': 'form-control form-control-sm'}}) }}
    </div>
    <div class="clear"></div>
    <!-- Code postal & ville -->
    <div class="col-md-4">
        <div class="row">
            <div class="col-12">
                <div class="input-group">
                    {{ form_widget(form.zipcode, {'attr': {'class': 'form-control form-control-sm w-25'}}) }}
                    {{ form_widget(form.city, {'attr': {'class': 'form-control form-control-sm w-75'}}) }}
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row g-2">


    <!-- Téléphone & email de contact -->
    <div class="col-md-12">
        <div class="row g-2">
            <div class="col-md-4">
                {{ form_label(form.contactEmail, 'Email de contact', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                {{ form_widget(form.contactEmail, {'attr': {'class': 'form-control form-control-sm'}}) }}
            </div>
            <div class="col-md-2">
                {{ form_label(form.contactPhone, 'Téléphone', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                {{ form_widget(form.contactPhone, {'attr': {'class': 'form-control form-control-sm'}}) }}
            </div>
        </div>
    </div>

    {% if app.request.attributes.get('_route') == 'app_admin_member_new' %}
    <div class="col-md-6">
        {{ form_label(form.password.first, '', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.password.first, {'attr': {'class': 'form-control form-control-sm'}}) }}
        {{ form_errors(form.password.first) }}
    </div>
        <div class="col-md-6">
            {{ form_label(form.password.second, '', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.password.second, {'attr': {'class': 'form-control form-control-sm'}}) }}
            {{ form_errors(form.password.first) }}
        </div>
    {% endif %}

    <!-- Bouton -->
    <div class="mt-4">
        <a class="btn btn-sm btn-outline-dark" href="/admin/dashboard"><i class="fa-duotone fa-solid fa-chevrons-left"></i>&nbsp;Retour</a>
        <button class="btn btn-outline-primary btn-sm">{{ button_label|default('Enregistrer') }}</button>
    </div>

</div>

{{ form_end(form) }}


